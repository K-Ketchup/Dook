<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:Dook.ViewModel"
             x:DataType="viewmodel:MainViewModel"
             xmlns:maps="clr-namespace:Microsoft.Maui.Controls.Maps;assembly=Microsoft.Maui.Controls.Maps"
             xmlns:sensors="clr-namespace:Microsoft.Maui.Devices.Sensors;assembly=Microsoft.Maui.Essentials"
             x:Class="Dook.MainPage"
             Title="{Binding Title}">

    <ContentPage.BindingContext>
        <viewmodel:MainViewModel />
    </ContentPage.BindingContext>

    <StackLayout
        Margin="5">

        <Map
        x:Name="mainmap" 
        MapType="Street" 
        IsShowingUser="true"
        IsTrafficEnabled="True">

            <x:Arguments>
                <MapSpan>
                    <x:Arguments>
                        <sensors:Location>
                            <x:Arguments>
                                <x:Double>{Binding CurrentLocationLatitude}</x:Double>
                                <x:Double>{Binding CurrentLocationLongitude}</x:Double>
                            </x:Arguments>
                        </sensors:Location>
                        <x:Double>0.01</x:Double>
                        <x:Double>0.01</x:Double>
                    </x:Arguments>
                </MapSpan>
            </x:Arguments>

        </Map>

        <Button
            Text="{Binding CurrentLocationLongitude}"
            Command="{Binding GetCurrentLocationCommand}"
            IsEnabled="{Binding IsNotBusy}"
            Margin="0"
            VerticalOptions="Center"
            HorizontalOptions="Center"/>
        <Button
            Text="{Binding CurrentLocationLongitude}"
            Command="{Binding GetCurrentLocationCommand}"
            IsEnabled="{Binding IsNotBusy}"
            Margin="0"
            VerticalOptions="Center"
            HorizontalOptions="Center"/>
          <Button
      Text="{Binding CurrentLocationLatitude}"
      Command="{Binding GetCurrentLocationCommand}"
      IsEnabled="{Binding IsNotBusy}"
      Margin="0"
      VerticalOptions="Center"
      HorizontalOptions="Center"/>
    </StackLayout>


</ContentPage>
    